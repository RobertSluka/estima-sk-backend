# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=estima_sk
POSTGRES_USER=estima_sk
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5433

# Full DSN — host is "db" inside Docker, "localhost" for local Python
DATABASE_URL=postgresql://estima_sk:changeme_in_production@db:5432/estima_sk

# Read API host port (published by docker-compose)
READ_API_PORT=8011

# ── Apify (Slovak portals) ──────────────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_api_token_here

# Apify Actor IDs — replace with actual Slovak-portal actor slugs (Phase 2).
# Placeholders until a working SK actor/task is identified.
APIFY_NEHNUTELNOSTI_ACTOR_ID=
APIFY_TOPREALITY_ACTOR_ID=
APIFY_REALITY_ACTOR_ID=

# How long to wait for an Apify run to finish (seconds)
APIFY_TIMEOUT_SECONDS=600
APIFY_POLL_INTERVAL_SECONDS=15

# ── Model artifacts ───────────────────────────────────────────────────────────
ARTIFACTS_DIR=/app/artifacts

# ── Outlier bounds (EUR — Slovak market) ────────────────────────────────────────
# Rough EUR bounds; tune once real SK data volume exists.
SALE_PRICE_MIN=20000
SALE_PRICE_MAX=5000000
RENT_PRICE_MIN=150
RENT_PRICE_MAX=10000
FLOOR_AREA_MIN=10
FLOOR_AREA_MAX=1000

# ── Report rendering (estima-report-service) ──────────────────────────────────
# When set, /reports/properties/{id}/pdf renders via the standalone
# estima-report-service (payload includes the NBS market-statistics section);
# empty keeps the internal WeasyPrint pipeline. From inside Docker on macOS use
# host.docker.internal to reach a service running on the host.
REPORT_SERVICE_URL=
REPORT_SERVICE_TIMEOUT_SECONDS=60

# ── Internal account/billing API (consumed by the estima-sk frontend) ─────────
# Shared secret for the /internal/* endpoints in src/read_api.py. Accounts are
# DISABLED while unset (endpoints return 503). Set the same value in the
# frontend's INTERNAL_API_KEY. Generate with: openssl rand -hex 32
INTERNAL_API_KEY=
